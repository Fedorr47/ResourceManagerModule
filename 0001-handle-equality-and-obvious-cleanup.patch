+		std::uint32_t nextDescId_{ 0 };
+		std::uint32_t nextFenceId_{ 0 };
+		std::unordered_map<TextureDescIndex, TextureHandle> descToTex_{};
+		std::unordered_map<std::uint32_t, bool> fenceSignaled_{};
