+                    pipelineDesc.DepthStencilState.StencilWriteMask = curState.depth.stencil.writeMask;
+                    pipelineDesc.DepthStencilState.FrontFace.StencilFailOp = ToD3DStencilOp(curState.depth.stencil.front.failOp);
